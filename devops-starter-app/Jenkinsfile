pipeline {
  agent any

  stages {
    stage('Clone') {
      steps {
        git branch: 'main', url: 'https://github.com/awslab-devops/devops-starter-app.git'
      }
    }

    stage('Build Docker Image') {
      steps {
        sh 'docker build -t devops-app .'
      }
    }

    stage('Tag Image') {
      steps {
        sh 'docker tag devops-app docker21devops/devops-app'
      }
    }

    stage('Docker Login & Push') {
      steps {
        withCredentials([usernamePassword(credentialsId: '84701967-e6ae-4a70-81e4-f0c4aea9e9cd', usernameVariable: 'docker21devops', passwordVariable: 'MyDockerpwd@123')]) {
          sh '''
          echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
          docker push docker21devops/devops-app:latest
          '''
        }
      }
    }
  }
}
    
